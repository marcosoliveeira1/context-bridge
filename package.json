{
    "name": "context-bridge",
    "displayName": "Context Bridge",
    "description": "Compile your project into AI context and spread AI suggestions back effortlessly",
    "version": "1.0.0",
    "engines": {
        "vscode": "^1.109.0"
    },
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "compilador-ai-sidebar",
                    "title": "Context Bridge",
                    "icon": "$(code)"
                }
            ]
        },
        "views": {
            "compilador-ai-sidebar": [
                {
                    "type": "webview",
                    "id": "compilador-ai-view",
                    "name": "Configurações"
                }
            ]
        },
        "commands": [
            {
                "command": "project.compileProject",
                "title": "Compile Project for AI"
            },
            {
                "command": "project.spreadProject",
                "title": "Spread Project"
            },
            {
                "command": "project.saveConfig",
                "title": "Save Context Bridge Config"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "pnpm run package",
        "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
        "watch": "npm-run-all -p watch:*",
        "watch:esbuild": "node esbuild.js --watch",
        "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
        "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
        "check-types": "tsc --noEmit",
        "lint": "eslint src"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.109.0",
        "esbuild": "^0.27.3",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.0"
    },
    "dependencies": {
        "eslint": "^10.0.3"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": " https://github.com/marcosoliveeira1/context-bridge.git"
    }
}